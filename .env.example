# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=troque-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco (produção)
DB_NAME=questoes
DB_USER=questoes
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# IA — Anthropic / Claude (chave única do sistema)
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_EFFORT=medium
AI_MAX_TOKENS=16000
AI_PRICE_INPUT_PER_MTOK=3.0
AI_PRICE_OUTPUT_PER_MTOK=15.0

# Quotas (tokens/mês)
QUOTA_TOKENS_DEFAULT=2000000
QUOTA_TOKENS_VISITOR=100000

# Visitante
VISITOR_EXPIRY_HOURS=48

# Uploads
MAX_UPLOAD_SIZE_MB=50
